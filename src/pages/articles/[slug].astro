---
import { getCollection, render } from 'astro:content';
import MainLayout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

// Les avatars devront être placés dans le dossier "public/assets/uploads/"
const AUTHORS_DATA: Record<string, { avatarUrl: string }> = {
  "Victor Zhâ": {
    avatarUrl: "/assets/uploads/avatar-victor.jpg"
  },
  "Paul Delachaux": {
    avatarUrl: "/assets/uploads/avatar-paul.jpg"
  }
};

const { article } = Astro.props;
const { Content } = await render(article);

// --- Articles similaires (même catégorie) ---
const tousLesArticles = await getCollection('articles');
const similaires = tousLesArticles
  .filter(art =>
    art.data.isVisible === true &&
    art.data.category.toLowerCase() === article.data.category.toLowerCase() &&
    art.id !== article.id
  )
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const autresRecents = tousLesArticles
  .filter(art =>
    art.data.isVisible === true &&
    art.id !== article.id &&
    !similaires.find(s => s.id === art.id)
  )
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const articlesSimilaires = [...similaires, ...autresRecents].slice(0, 3);

const currentAuthorName = article.data.author || "Auteur Anonyme";
const authorInfo = AUTHORS_DATA[currentAuthorName] || { avatarUrl: "/assets/uploads/avatar-default.jpg"};
console.log("Auteur actuel :", currentAuthorName, "Avatar :", authorInfo.avatarUrl);
const articleHeroImage = article.data.article_image || article.data.image || "/assets/uploads/default-placeholder.jpg";

const rawDate = article.data.date;
const dateObj = rawDate instanceof Date ? rawDate : new Date(rawDate);
const options: Intl.DateTimeFormatOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
const dateAffichee = dateObj.toLocaleDateString('fr-FR', options);
const heureAffichee = dateObj.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
---

<MainLayout title={article.data.title}>
  <div class="article-wrapper">
    <div class="article-container">

      {/* --- BANDEAU SUPERIEUR : TITRE & META --- */}
      <header class="article-header">
        <h1 class="main-title">{article.data.title}</h1>
        <p class="main-description">{article.data.description}</p>

        <div class="author-meta-block">
          <img src={authorInfo.avatarUrl} alt={`Portrait de ${currentAuthorName}`} class="author-avatar" />
          <div class="author-text-meta">
            <p class="author-name">Par {currentAuthorName}</p>
            <p class="publication-date">
              Lecture en {article.data.reading_time || 5} Minutes - Publié le {dateAffichee} à {heureAffichee}
            </p>
          </div>
        </div>
      </header>

      {/* --- GRILLE PRINCIPALE (CONTENU VS SIDEBAR) --- */}
      <div class="article-grid">

        {/* Colonne Gauche : Image et texte Markdown */}
        <main class="article-main-content">
          <div class="hero-image-wrapper">
            <img src={articleHeroImage} alt={`Illustration de l'article : ${article.data.title}`} class="hero-img" />
          </div>

          <div class="prose-content">
            <Content />
          </div>
        </main>

        {/* Colonne Droite : Articles similaires */}
        <aside class="article-sidebar">
          <div class="sidebar-sticky-box">
            {articlesSimilaires.length > 0 && (
              <div class="sidebar-similaires">
                <p class="sidebar-label">À LIRE AUSSI</p>
                {articlesSimilaires.map(art => (
                  <a href={`/articles/${art.id}`} class="sidebar-card">
                    {(art.data.article_image || art.data.image) && (
                      <img
                        src={art.data.article_image || art.data.image}
                        alt={art.data.title}
                        class="sidebar-card-img"
                      />
                    )}
                    <div class="sidebar-card-body">
                      <p class="sidebar-card-tag">{art.data.category.toUpperCase()}</p>
                      <p class="sidebar-card-title">{art.data.title}</p>
                    </div>
                  </a>
                ))}
              </div>
            )}
          </div>
        </aside>

      </div>

      {/* --- BLOC DE FIN DE PAGE : TRANSPARENCE JOURNALISTIQUE --- */}
      <footer class="article-footer-transparency">
        <div class="transparency-column">
          <h3>A propos de l'auteur</h3>
          <p>{article.data.author_about || "Aucune information fournie pour le moment."}</p>
        </div>

        <div class="transparency-column column-border">
          <h3>Déclaration d'intérêt :</h3>
          <p>{article.data.author_interests || "L'auteur déclare n'avoir aucun conflit d'intérêt."}</p>
        </div>

        <div class="transparency-column">
          <h3>Sources consultables</h3>
          {article.data.consulted_sources && article.data.consulted_sources.length > 0 ? (
            <ul class="sources-list">
              {article.data.consulted_sources.map((src: any) => (
                <li>
                  {src.source_url ? (
                    <a href={src.source_url} target="_blank" rel="noopener noreferrer">{src.source_title}</a>
                  ) : (
                    src.source_title
                  )}
                </li>
              ))}
            </ul>
          ) : (
            <p>Aucune source externe enregistrée.</p>
          )}
        </div>
      </footer>

    </div>
  </div>
</MainLayout>

<style is:global>
  body {
    background-color: #000000 !important;
    color: #ffffff !important;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    margin: 0;
  }

  .article-wrapper {
    background-color: #02001d;
    max-width: 1200px;
    margin: 40px auto;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }

  .article-container {
    padding: 50px 40px;
  }

  /* --- HEADER STYLES --- */
  .article-header {
    border-bottom: 1px solid #1f2937;
    padding-bottom: 30px;
    margin-bottom: 30px;
    text-align: left;
  }

  .main-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    line-height: 1.3;
    margin: 0 0 15px 0;
  }

  .main-description {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: #ffffff;
    line-height: 1.5;
    margin: 0 0 30px 0;
  }

  /* --- ZONE AUTEUR --- */
  .author-meta-block {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .author-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    background-color: #374151;
    flex-shrink: 0;
  }

  .author-text-meta {
    display: flex;
    flex-direction: column;
    gap: 0;
    justify-content: center;
  }

  .author-name {
    margin: 0;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-style: italic;
    color: #ffffff;
    line-height: 1.3;
  }

  .publication-date {
    margin: 0;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-style: italic;
    color: #ffffff;
    line-height: 1.3;
  }

  /* --- STRUCTURE EN GRILLE --- */
  .article-grid {
    display: grid;
    grid-template-columns: 7.5fr 2.5fr;
    gap: 40px;
    align-items: start;
  }

  /* Zone principale & Image */
  .article-main-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .hero-image-wrapper {
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    background-color: #111827;
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 550px;
    object-fit: cover;
  }

  /* --- CONTENU MARKDOWN PROSE --- */
  .prose-content {
    color: #d1d5db;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .prose-content p {
    margin-bottom: 24px;
  }

  .prose-content h2 {
    font-size: 1.7rem;
    color: #ffffff;
    margin-top: 40px;
    margin-bottom: 20px;
    font-weight: 700;
  }

  /* --- SIDEBAR DROITE --- */
  .article-sidebar {
    height: 100%;
    background: #02001d;
    background-color: #02001d;
  }

  .sidebar-sticky-box {
    position: sticky;
    top: 20px;
    background-color: #02001d;
  }

  /* --- ARTICLES SIMILAIRES --- */
  .sidebar-similaires {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .sidebar-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #ea580c;
    margin: 0 0 4px 0;
  }

  .sidebar-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    border-bottom: 1px solid #1f2937;
    padding-bottom: 16px;
  }

  .sidebar-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sidebar-card-img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .sidebar-card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-card-tag {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: #ea580c;
  }

  .sidebar-card-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .sidebar-card:hover .sidebar-card-title {
    color: #d1d5db;
  }

  /* --- FOOTER : GRILLE TRIPLE COLONNE --- */
  .article-footer-transparency {
    margin-top: 60px;
    border-top: 2px solid #ea580c;
    padding-top: 30px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .transparency-column h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 0 15px 0;
    font-weight: 700;
  }

  .transparency-column p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #9ca3af;
    margin: 0;
  }

  .column-border {
    border-left: 1px solid #ea580c;
    border-right: 1px solid #ea580c;
    padding: 0 30px;
  }

  .sources-list {
    margin: 0;
    padding-left: 18px;
    font-size: 0.9rem;
    color: #9ca3af;
  }

  .sources-list li {
    margin-bottom: 8px;
  }

  .sources-list a {
    color: #3b82f6;
    text-decoration: none;
  }

  .sources-list a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .article-wrapper {
      margin: 0;
      border-radius: 0;
    }
    .article-container {
      padding: 30px 20px;
    }
    .article-grid {
      grid-template-columns: 1fr;
    }
    .article-sidebar {
      order: -1; /* Les articles similaires passent au-dessus sur mobile */
    }
    .article-footer-transparency {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .column-border {
      border-left: none;
      border-right: none;
      padding: 0;
    }
  }
</style>
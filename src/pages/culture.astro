---
import MainLayout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const tousLesArticles = await getCollection('articles');

// On filtre uniquement pour la culture
const articlesCulture = tousLesArticles
    .filter(art => art.data.category === 'culture')
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<MainLayout title="Culture">
    <div class="main-grid">
        <section class="article-une">
            <h1 style="color: #ff8826; margin-bottom: 30px;">L'actualité Culturelle</h1>

            {articlesCulture.length > 0 ? (
                articlesCulture.map(art => (
                    <div style="background: white; padding: 20px; border-radius: 8px; margin-bottom: 20px; color: #1a1a1a;">
                        <h2 style="margin-top: 0;">{art.data.title}</h2>
                        <img src={art.data.image} alt="" style="width: 100%; height: auto; margin: 15px 0; border-radius: 4px;" />
                        <p>{art.data.description}</p>
                        <a href={`/articles/${art.id}`} style="color: #ff8826; font-weight: bold; text-decoration: none;">Lire l'article →</a>
                    </div>
                ))
            ) : (
                <p style="color: white;">Aucun article culturel pour le moment.</p>
            )}
        </section>

        <aside>
            <div class="article-sidebar">
                <h3 style="color: white;">Sorties de la semaine</h3>
                <p style="color: #ccc; font-size: 0.9rem;">Cinéma, Musique et Expos...</p>
            </div>
        </aside>
    </div>
</MainLayout>
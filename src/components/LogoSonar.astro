<div class="logo-container">
  <canvas id="sonar-logo" width="60" height="60"></canvas>
  <div class="logo-text">
    <span class="title">LE SONAR</span>
    <span class="subtitle">MÉDIA</span>
  </div>
</div>

<script>
  function initSonar() {
    const canvas = document.getElementById('sonar-logo') as HTMLCanvasElement;
    if (!canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const W = canvas.width;
    const H = canvas.height;
    const cx = W / 2;
    const cy = H / 2;
    const R = 26; // Rayon ajusté pour la topbar

    const targets = [
      { dist: 0.60, angle: 0.88, size: 6, opacity: 1 },
      { dist: 0.30, angle: 0.55, size: 4, opacity: 0.65 }
    ];

    let sweep = -Math.PI / 2;
    const SPEED = 0.012;
    const TRAIL = Math.PI * 1.1;

    function pingOpacity(targetAngle: number, sweep: number) {
      let diff = ((sweep - targetAngle) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
      if (diff > Math.PI * 2) diff -= Math.PI * 2;
      if (diff < 0.08) return 1.0;
      if (diff < TRAIL) return Math.max(0, 1 - diff / TRAIL);
      return 0;
    }

    function draw() {
      if (!ctx || !canvas) return;
      ctx.clearRect(0, 0, W, H);

      ctx.save();
      ctx.beginPath();
      ctx.arc(cx, cy, R, 0, Math.PI * 2);
      ctx.clip();

      // Fond transparent/sombre intégré à la topbar
      ctx.fillStyle = '#062016';
      ctx.fillRect(0, 0, W, H);

      // Faisceau radar
      const steps = 30;
      for (let i = 0; i < steps; i++) {
        const a0 = sweep - (i / steps) * TRAIL;
        const a1 = sweep - ((i + 1) / steps) * TRAIL;
        const alpha = (1 - i / steps);
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, R, a0, a1, true);
        ctx.closePath();
        ctx.fillStyle = `rgba(26,140,96,${alpha * 0.55})`;
        ctx.fill();
      }

      // Cercles concentriques
      ctx.strokeStyle = '#3ECFA0';
      [R, R * 0.74, R * 0.48, R * 0.23].forEach((r, i) => {
        ctx.globalAlpha = [0.8, 0.5, 0.4, 0.3][i];
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.stroke();
      });
      ctx.globalAlpha = 1;

      // Ligne rotative
      const ex = cx + Math.cos(sweep) * R;
      const ey = cy + Math.sin(sweep) * R;
      ctx.strokeStyle = '#6FEBB0';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(ex, ey);
      ctx.stroke();

      // Cibles "?"
      targets.forEach(t => {
        const tAngle = t.angle - Math.PI / 2;
        const tx = cx + Math.cos(tAngle) * R * t.dist;
        const ty = cy + Math.sin(tAngle) * R * t.dist;
        const op = pingOpacity(tAngle, sweep);

        if (op > 0.01) {
          ctx.save();
          ctx.globalAlpha = op * t.opacity;
          ctx.font = `bold ${t.size}px Georgia, serif`;
          ctx.fillStyle = '#CDFAE8';
          ctx.fillText('?', tx - 2, ty + 2);
          ctx.restore();
        }
      });

      // Point central
      ctx.fillStyle = '#CDFAE8';
      ctx.beginPath();
      ctx.arc(cx, cy, 1.5, 0, Math.PI * 2);
      ctx.fill();

      ctx.restore();

      sweep += SPEED;
      if (sweep > Math.PI * 1.5) sweep -= Math.PI * 2;

      requestAnimationFrame(draw);
    }

    draw();
  }

  // S'exécute au chargement initial
  initSonar();
  // Support si tu utilises Astro View Transitions plus tard
  document.addEventListener('astro:page-load', initSonar);
</script>

<style>
  .logo-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
  }
  #sonar-logo {
    border-radius: 50%;
    border: 1px solid #3ECFA0;
    box-shadow: 0 0 8px rgba(62, 207, 160, 0.3);
  }
  .logo-text {
    display: flex;
    flex-direction: column;
    font-family: Georgia, serif;
  }
  .title {
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 2px;
    color: #CDFAE8;
    line-height: 1.1;
  }
  .subtitle {
    font-size: 9px;
    letter-spacing: 4px;
    color: #3ECFA0;
  }
</style>